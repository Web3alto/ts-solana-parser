{
  "name": "solana-swap-parser",
  "version": "1.0.0",
  "description": "Solana transaction parser with full instruction decoding and DEX swap detection for 10 protocols. Built on @solana/kit.",
  "module": "src/lib.ts",
  "types": "src/lib.ts",
  "type": "module",
  "exports": {
    ".": "./src/lib.ts"
  },
  "files": [
    "src/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check src/ test/",
    "lint:fix": "bunx biome check --write src/ test/",
    "format": "bunx prettier --write src/ test/ tools/",
    "format:check": "bunx prettier --check src/ test/ tools/",
    "verify": "bun run typecheck && bun run lint && bun run format:check && bun run test",
    "bench": "bun run tools/bench.ts"
  },
  "dependencies": {
    "@solana-program/address-lookup-table": "^0.11.0",
    "@solana-program/compute-budget": "^0.14.0",
    "@solana-program/memo": "^0.11.0",
    "@solana-program/system": "^0.12.0",
    "@solana-program/token": "^0.11.0",
    "@solana-program/token-2022": "^0.9.0",
    "@solana/kit": "^6.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "latest",
    "playwright": "^1.58.2",
    "prettier": "^3.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "license": "MIT",
  "author": "alto",
  "repository": {
    "type": "git",
    "url": "https://github.com/Web3alto/solana-parser-v2.git"
  },
  "homepage": "https://github.com/Web3alto/solana-parser-v2",
  "bugs": {
    "url": "https://github.com/Web3alto/solana-parser-v2/issues"
  },
  "keywords": ["solana", "parser", "swap", "dex", "transaction", "mev"],
  "engines": {
    "bun": ">=1.0.0"
  }
}
