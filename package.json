{
  "name": "ts-solana-parser",
  "version": "1.1.0",
  "description": "Solana transaction parser with full instruction decoding, DEX swap detection for 11 protocols, Jupiter aggregator routing, and token metadata resolution. Built on @solana/kit.",
  "main": "./dist/lib.js",
  "module": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/lib.ts",
      "import": {
        "types": "./dist/lib.d.ts",
        "default": "./dist/lib.js"
      }
    }
  },
  "files": [
    "src/",
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "bunx tsgo --noEmit",
    "typecheck:tsgo": "bunx tsgo --noEmit",
    "typecheck:tsc": "bunx tsc --noEmit",
    "lint": "bunx biome check src/ test/",
    "lint:fix": "bunx biome check --write src/ test/",
    "format": "bunx prettier --write src/ test/ tools/",
    "format:check": "bunx prettier --check src/ test/ tools/",
    "verify": "bun run typecheck && bun run lint && bun run format:check && bun run test",
    "bench": "bun run tools/bench.ts"
  },
  "dependencies": {
    "@solana-program/address-lookup-table": "^0.11.0",
    "@solana/kit": "^6.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "latest",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "prettier": "^3.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "license": "MIT",
  "author": "alto",
  "repository": {
    "type": "git",
    "url": "https://github.com/Web3alto/ts-solana-parser.git"
  },
  "homepage": "https://github.com/Web3alto/ts-solana-parser",
  "bugs": {
    "url": "https://github.com/Web3alto/ts-solana-parser/issues"
  },
  "keywords": ["solana", "parser", "swap", "dex", "transaction", "mev"],
  "engines": {
    "node": ">=18",
    "bun": ">=1.0.0"
  }
}
